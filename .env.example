# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://crm.zainhub.ae"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Portal JWT
PORTAL_JWT_SECRET="generate-with-openssl-rand-base64-32"

# Resend (transactional email)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="CRM <noreply@zainhub.ae>"

# UploadThing (file uploads)
UPLOADTHING_TOKEN="your_uploadthing_token"

# Content Security Policy — set "1" to run CSP in report-only mode (dev/staging)
CSP_REPORT_ONLY="0"

# Comma-separated list of additional allowed image hostnames for next/image
NEXT_IMAGE_HOSTS=""

# NEXTAUTH_URL — possibly unused — verify (NextAuth v5 typically infers this)

# ============================================================================
# Database — non-pooled connection for `prisma migrate` (Prisma 7 / D-005)
# Set to the Neon "-direct" host (no -pooler suffix). Falls back to DATABASE_URL.
# ============================================================================
DIRECT_URL=""

# ============================================================================
# Observability (Sentry) — graceful no-op when unset
# ============================================================================
# Public DSN exposed to the browser bundle (client-side error capture)
NEXT_PUBLIC_SENTRY_DSN=""
# Server-side DSN (route handlers, server components)
SENTRY_DSN=""
# Optional: enable Replay (sessions sample at 10%, errors at 100%)
NEXT_PUBLIC_SENTRY_REPLAY="0"

# ============================================================================
# Rate limiting (Upstash Redis) — graceful in-memory fallback when unset
# Production requires this for cross-instance rate limiting on serverless.
# Convention: use the _REST_* form (Upstash SDK convention) — D-008
# ============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================================
# Logger (pino)
# ============================================================================
# Log level: debug | info | warn | error. Defaults: 'info' in prod, 'debug' in dev.
LOG_LEVEL="info"
