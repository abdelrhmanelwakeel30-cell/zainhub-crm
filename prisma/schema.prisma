model ClientService {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  clientServiceNumber String
  companyId           String?
  company             Company?  @relation(fields: [companyId], references: [id])
  contactId           String?
  contact             Contact?  @relation("ClientServiceContact", fields: [contactId], references: [id])
  serviceId           String?
  service             Service?  @relation(fields: [serviceId], references: [id])
  packageId           String?
  package             ServicePackage? @relation(fields: [packageId], references: [id])
  assignedToId        String?
  assignedTo          User?     @relation("ClientServiceAssignee", fields: [assignedToId], references: [id])
  serviceName         String
  status              String    @default("ACTIVE")
